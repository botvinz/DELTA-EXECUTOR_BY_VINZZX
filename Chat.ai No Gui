-- ══════════════════════════════════════
-- FUNGSI CARI JAWABAN
-- ══════════════════════════════════════
local function getReply(msg)
	msg = msg:lower()
	for _, e in ipairs(KB) do
		for _, k in ipairs(e.keys) do
			if msg:find(k) then
				return e.reply
			end
		end
	end
	local defaults = {
		"Hmm, aku belum tahu jawabannya. Coba tanya hal lain!",
		"Pertanyaan bagus! Sayangnya aku masih belajar.",
		"Aku tidak yakin soal itu. Ada yang lain?",
		"Coba tanya admin game ya!",
	}
	return defaults[math.random(1, #defaults)]
end

-- ══════════════════════════════════════
-- FUNGSI KIRIM CHAT
-- ══════════════════════════════════════
local function sendSystemChat(player, message)
	-- Kirim sebagai System Message ke player tertentu
	local success, err = pcall(function()
		game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
			Text = "[" .. BOT_NAME .. "]: " .. message,
			Color = Color3.fromRGB(167, 139, 250),
			Font = Enum.Font.GothamBold,
			TextSize = 14,
		})
	end)
end

-- Pakai RemoteEvent untuk kirim ke client
local RE = Instance.new("RemoteEvent")
RE.Name = "AIChatEvent"
RE.Parent = game:GetService("ReplicatedStorage")

-- LocalScript handler (dibuat otomatis)
local ls_src = [[
local RE = game:GetService("ReplicatedStorage"):WaitForChild("AIChatEvent")
local StarterGui = game:GetService("StarterGui")
RE.OnClientEvent:Connect(function(msg, color)
	StarterGui:SetCore("ChatMakeSystemMessage", {
		Text = msg,
		Color = color or Color3.fromRGB(167, 139, 250),
		Font = Enum.Font.GothamBold,
		TextSize = 14,
	})
end)
]]

local function injectLocalScript(player)
	local char = player.Character or player.CharacterAdded:Wait()
	local ls = Instance.new("LocalScript")
	ls.Source = ls_src
	ls.Parent = player:WaitForChild("PlayerGui")
end

-- ══════════════════════════════════════
-- MAIN LOGIC
-- ══════════════════════════════════════
local function onPlayerAdded(player)
	-- Inject local script
	task.spawn(injectLocalScript, player)

	-- Sambut player
	task.wait(3)
	RE:FireClient(player, "[🤖 AI]: Halo " .. player.Name .. "! Ketik !ai <pertanyaan> untuk tanya aku!", Color3.fromRGB(167,139,250))

	-- Listen chat
	player.Chatted:Connect(function(msg)
		local lower = msg:lower()

		-- Cek prefix
		if lower:sub(1, #PREFIX) == PREFIX then
			local question = msg:sub(#PREFIX + 2):match("^%s*(.-)%s*$")
			if question and question ~= "" then
				task.wait(REPLY_DELAY)
				local reply = getReply(question)
				RE:FireClient(player, "[🤖 AI]: " .. reply, Color3.fromRGB(167,139,250))
			else
				RE:FireClient(player, "[🤖 AI]: Ketik pertanyaanmu setelah !ai ya! Contoh: !ai cara main", Color3.fromRGB(167,139,250))
			end
		end
	end)
end

Players.PlayerAdded:Connect(onPlayerAdded)

-- Untuk player yang sudah ada
for _, p in ipairs(Players:GetPlayers()) do
	task.spawn(onPlayerAdded, p)
end

print("[AI Chat] System loaded! Prefix: " .. PREFIX)
