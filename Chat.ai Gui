-- FUNGSI BUAT BUBBLE CHAT
-- ══════════════════════════════════════
local msgCount = 0

local function addBubble(text, isUser)
	msgCount += 1
	local bubble = Instance.new("Frame")
	bubble.Size = UDim2.new(1,0,0,0)
	bubble.AutomaticSize = Enum.AutomaticSize.Y
	bubble.BackgroundTransparency = 1
	bubble.LayoutOrder = msgCount
	bubble.Parent = scroll

	local inner = Instance.new("Frame")
	inner.AutomaticSize = Enum.AutomaticSize.XY
	inner.BackgroundColor3 = isUser and Color3.fromRGB(124,58,237) or Color3.fromRGB(30,30,55)
	inner.BorderSizePixel = 0
	inner.Parent = bubble
	Instance.new("UICorner", inner).CornerRadius = UDim.new(0,10)
	local ip = Instance.new("UIPadding", inner)
	ip.PaddingTop = UDim.new(0,8); ip.PaddingBottom = UDim.new(0,8)
	ip.PaddingLeft = UDim.new(0,10); ip.PaddingRight = UDim.new(0,10)

	if isUser then
		inner.Position = UDim2.new(1,-10,0,0)
		inner.AnchorPoint = Vector2.new(1,0)
	else
		inner.Position = UDim2.new(0,10,0,0)
	end

	local lbl = Instance.new("TextLabel", inner)
	lbl.Size = UDim2.new(0,180,0,0)
	lbl.AutomaticSize = Enum.AutomaticSize.Y
	lbl.BackgroundTransparency = 1
	lbl.Text = text
	lbl.TextColor3 = Color3.fromRGB(220,220,255)
	lbl.Font = Enum.Font.Gotham
	lbl.TextSize = 12
	lbl.TextWrapped = true
	lbl.TextXAlignment = Enum.TextXAlignment.Left

	-- Typing effect untuk AI
	if not isUser then
		lbl.Text = ""
		task.spawn(function()
			for i = 1, #text do
				lbl.Text = text:sub(1,i)
				task.wait(0.02)
			end
		end)
	end

	-- Auto scroll ke bawah
	task.wait(0.05)
	scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
end

